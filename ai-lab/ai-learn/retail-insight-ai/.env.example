# 复制为 backend/.env 后按部署环境调整。不要在此文件写入真实密钥。
APP_NAME=Retail Insight AI
APP_ENV=local
LOG_LEVEL=INFO
SERVICE_NAME=retail-insight-ai
TASK_EXECUTION_MODE=background
RESEARCH_PROVIDER=static
DATA_PROVIDER=static
CORS_ORIGINS=["http://127.0.0.1:5173"]
WORKFLOW_STEP_DELAY_SECONDS=0.05
STATIC_RESEARCH_FAIL=false
