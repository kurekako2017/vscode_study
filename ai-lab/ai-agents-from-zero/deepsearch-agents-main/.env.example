# DeepSearch Agents 环境变量示例
# 复制为 .env 后按本机实际服务地址和密钥调整，不要提交真实密钥

# LLM 配置
# 默认主路径是 OpenRouter；OpenRouter 返回 402 且已配置 NVIDIA 时会自动兜底。
# 如果你想显式控制首选提供方，可设置 LLM_PROVIDER=openrouter|nvidia|auto
LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=你的_openrouter_api_key
LLM_QWEN_MAX=openai/gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=1024

# 可选：NVIDIA 兼容接口，OpenRouter 402 时可自动兜底使用
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_API_KEY=你的_nvidia_api_key
# NVIDIA_MODEL=你的_nvidia_model

# Tavily 配置
# 在 https://app.tavily.com/ 注册账号，然后创建API KEY
TAVILY_API_KEY=你的_TAVILY_API_KEY

# 本地知识库配置
# 默认直接使用仓库内的 docs/knowledge_base/ 目录，不需要额外环境变量

# MySQL 配置
# 当前工作区建议直接连 NAS 上的 JtProject MySQL；
# 如果你之后要换成本机 Docker MySQL，再把 host/port 改掉即可。
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ecommjava
MYSQL_HOST=192.168.10.2
MYSQL_PORT=3306
# 与初始化 SQL 和 MySQL 服务保持一致，保证中文数据按 utf8mb4 读写
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL
