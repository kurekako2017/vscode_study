# DeepSearch Agents 环境变量示例
# 复制为 .env 后按本机实际服务地址和密钥调整，不要提交真实密钥

# LLM 配置
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=你的大模型_API_KEY
LLM_QWEN_MAX=qwen-max

# 如果你使用 OpenRouter，也可以改用这一组变量名：
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=你的_openrouter_api_key
# LLM_QWEN_MAX=你在 OpenRouter 中启用的模型名

# Tavily 配置
# 在 https://app.tavily.com/ 注册账号，然后创建API KEY
TAVILY_API_KEY=你的_TAVILY_API_KEY

# RAGFlow 配置
RAGFLOW_API_URL=http://your-ragflow-host
RAGFLOW_API_KEY=ragflow-your-api-key

# MySQL 配置
# 当前工作区建议直接连 NAS 上的 JtProject MySQL；
# 如果你之后要换成本机 Docker MySQL，再把 host/port 改掉即可。
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ecommjava
MYSQL_HOST=192.168.10.2
MYSQL_PORT=3306
# 与初始化 SQL 和 MySQL 服务保持一致，保证中文数据按 utf8mb4 读写
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL
