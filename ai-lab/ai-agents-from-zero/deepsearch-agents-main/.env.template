# DeepSearch Agents 环境模板
#
# 复制为 `.env` 后按你的实际服务地址和密钥填写。
# 这个模板同时兼容 OpenAI-Compatible 和 OpenRouter 两种接法。

########################################
# 1) 大模型接入
########################################

# 方案 A: OpenAI-Compatible
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your_openai_compatible_api_key
LLM_QWEN_MAX=qwen-max

# 方案 B: OpenRouter
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=your_openrouter_api_key
# LLM_QWEN_MAX=openai/gpt-4o-mini
# LLM_MAX_COMPLETION_TOKENS=1024

########################################
# 2) 互联网搜索
########################################

TAVILY_API_KEY=your_tavily_api_key

########################################
# 3) RAGFlow 知识库
########################################

RAGFLOW_API_URL=http://your-ragflow-host
RAGFLOW_API_KEY=your_ragflow_api_key

########################################
# 4) MySQL 业务库
########################################

# 当前工作区推荐直接连 NAS 上的 JtProject MySQL；
# 如果后续要换成本机 Docker MySQL，再把 host/port 改掉即可。
MYSQL_HOST=192.168.10.2
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ecommjava
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL

########################################
# 5) 可选说明
########################################

# 前端默认访问后端：
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
