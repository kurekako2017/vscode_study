# DeepSearch Agents 环境模板
#
# 复制为 `.env` 后按你的实际服务地址和密钥填写。
# 这个模板同时兼容 OpenAI-Compatible 和 OpenRouter 两种接法。

########################################
# 1) 大模型接入
########################################

# 默认主路径是 OpenRouter；OpenRouter 返回 402 且已配置 NVIDIA 时会自动兜底。
# 如果你想显式控制首选提供方，可设置 LLM_PROVIDER=openrouter|nvidia|auto
LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_QWEN_MAX=openai/gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=1024

# 可选：NVIDIA 兼容接口，OpenRouter 402 时可自动兜底使用
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_API_KEY=your_nvidia_api_key
# NVIDIA_MODEL=your_nvidia_model

########################################
# 2) 互联网搜索
########################################

TAVILY_API_KEY=your_tavily_api_key

########################################
# 3) 本地知识库
########################################

# 本地知识库默认直接使用仓库内的 docs/knowledge_base/ 目录，
# 不需要额外的外部服务地址或 API Key。

########################################
# 4) MySQL 业务库
########################################

# 当前工作区推荐直接连 NAS 上的 JtProject MySQL；
# 如果后续要换成本机 Docker MySQL，再把 host/port 改掉即可。
MYSQL_HOST=192.168.10.2
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ecommjava
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL

########################################
# 5) 可选说明
########################################

# 前端默认访问后端：
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
