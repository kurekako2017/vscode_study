# 后端大模型配置：OpenRouter -> NVIDIA -> 本地 Ollama 依次回退
LLM_PROVIDER_ORDER=openrouter,nvidia,ollama
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=openai/gpt-4o-mini
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=nvidia/llama-3.3-nemotron-super-49b-v1
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL_NAME=qwen2.5-coder:1.5b
OLLAMA_API_KEY=ollama
LLM_API_KEY=
LLM_MODEL_NAME=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1
MOCK_MODE=false

# 元数据 MySQL
DB_META_HOST=localhost
DB_META_PORT=3306
DB_META_USER=didilili
DB_META_PASSWORD=dili123
DB_META_DATABASE=meta

# 教学数仓 MySQL
DB_DW_HOST=localhost
DB_DW_PORT=3306
DB_DW_USER=didilili
DB_DW_PASSWORD=dili123
DB_DW_DATABASE=dw

# 向量库
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_EMBEDDING_SIZE=1024

# Embedding 服务
EMBEDDING_HOST=localhost
