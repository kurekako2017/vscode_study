flowchart TD
    A[ログインユーザー解決] --> B{ユーザー名取得済?}
    B -- No --> C[cartMsg設定]
    C --> D[商品一覧へ戻る]
    B -- Yes --> E[UserService.getUserByUsername]
    E --> F{ROLE_ADMIN?}
    F -- Yes --> G[管理画面へ誘導]
    F -- No --> H[既存Cart探索]
    H --> I{Cart有?}
    I -- No --> J[CartService.addCart]
    I -- Yes --> K[既存Cart使用]
    J --> L[ProductService.getProduct]
    K --> L
    L --> M{商品存在?}
    M -- No --> N[失敗メッセージ]
    M -- Yes --> O[CartProductDao.addCartProduct]
    O --> P[/user/cartへリダイレクト]
