# Base path for the app if deployed under a subpath (optional)
NEXT_PUBLIC_BASE_PATH=

# Supabase settings (optional)
# For server-side API read access you can set SUPABASE_URL and SUPABASE_ANON_KEY
SUPABASE_URL=
SUPABASE_ANON_KEY=

# For data migration or elevated privileges use SUPABASE_SERVICE_ROLE (keep secret)
SUPABASE_SERVICE_ROLE=
# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 邮件服务（Brevo/SendinBlue）
BREVO_API_KEY=your-brevo-api-key
CONTACT_EMAIL=info@yourcompany.com

# 站点配置
NEXT_PUBLIC_SITE_URL=https://yourcompany.com
NEXT_PUBLIC_SITE_NAME=公司名称
